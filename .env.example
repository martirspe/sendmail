API_PORT=8000

# Ruta del endpoint de envío (solo el segmento final)
API_ROUTE=sendmail

# Prefijo opcional si la API vive en un subdirectorio
# Ejemplos:
#   vacío     → https://tudominio.com/sendmail
#   /api      → https://tudominio.com/api/sendmail
#   /mail/v1  → https://tudominio.com/mail/v1/sendmail
API_BASE_PATH=

# SMTP — usa el host que indica cPanel → Email Accounts → Connect Devices
# NO dejes mail.tudominio.com (es solo un ejemplo). Debe coincidir con el certificado TLS.
# Hosting Alka/cPanel suele ser: mail.host.alka.cloud o mail.tudominio.com (tu dominio real)
EMAIL_HOST=mail.tudominio.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=correo@tudominio.com
EMAIL_PASSWORD=your-password
# Usar comillas SIMPLES envolviendo todo el valor (compatible con cPanel/shell)
EMAIL_FROM='Mi Empresa <correo@tudominio.com>'

# Solo si el hosting exige ignorar mismatch TLS (menos seguro; preferir EMAIL_HOST correcto)
# EMAIL_TLS_REJECT_UNAUTHORIZED=false

# Seguridad
API_KEY=your-secret-api-key

# Orígenes del frontend separados por coma, o * para permitir todos
# Ejemplo: https://tudominio.com,https://www.tudominio.com,http://localhost:4200
CORS_ORIGIN=*

# Activar si la API está detrás de un proxy inverso (Apache, Nginx, cPanel)
TRUST_PROXY=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=30

# Opcional
BODY_LIMIT=100kb
LOG_LEVEL=info
