# Plantilla de proxy Apache — frontend y API en dominios distintos
#
# Sustituir:
#   FRONTEND_PATH   → ruta pública en el frontend (ej. sendmail)
#   API_URL         → URL completa del endpoint en tu API (ej. https://api.tudominio.com/sendmail)
#   YOUR_API_KEY    → misma clave que API_KEY en el .env de la API

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{REQUEST_METHOD} POST
  RewriteRule ^FRONTEND_PATH$ API_URL [P,L,E=PROXY_SENDMAIL:1]
</IfModule>

<IfModule mod_ssl.c>
  SSLProxyEngine On
</IfModule>

<IfModule mod_headers.c>
  RequestHeader set X-API-Key "YOUR_API_KEY" env=PROXY_SENDMAIL
</IfModule>
