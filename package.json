{
  "name": "sendmail",
  "version": "3.0.3",
  "description": "API desarrollada con NodeJS, ExpressJS y Nodemailer para el envío de correos electrónicos.",
  "main": "app.js",
  "scripts": {
    "start": "node scripts/start.js",
    "dev": "nodemon app.js",
    "test": "jest --runInBand --forceExit",
    "generate:api-key": "node scripts/generate-api-key.js --write",
    "install:prod": "npm install --omit=dev",
    "setup": "node scripts/setup.js"
  },
  "keywords": [],
  "author": "MartiPE",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.1.4",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "nodemailer": "^9.0.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/nodemailer": "^6.4.8",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
